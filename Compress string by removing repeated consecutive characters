#include<iostream>
#include<string>
using namespace std;
string removeConsecutiveDuplicates(string &s)
{
    int n=s.length();
    if(n<2) return s;
    int j=0;
    for(int i=1;i<n;i++)
    {
        if(s[i]!=s[j])
        {
            j++;
            s[j]=s[i];
        }

    }
    s.resize(j+1);
    return s;
}
int main()
{
    string s;
    getline(cin,s);
    string ans=removeConsecutiveDuplicates(s);
    cout<<ans;
}

