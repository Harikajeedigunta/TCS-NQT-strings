#include<iostream>
using namespace std;
string replaceSpaces(string &s)
{
    int n=s.length();
    int space_count=0;
    for(char c:s)
    {
        if(c==' ') space_count++;
    }
    int newLength=n+2*space_count;
    s.resize(newLength);
    int i=n-1;
    int j=newLength-1;
    while(i>=0)
    {
        if(s[i]==' ')
        {
            s[j]='0';
            s[j-1]='2';
            s[j-2]='%';
            j-=3;
        }
        else
        {
            s[j]=s[i];
            j--;
        }
        i--;
    }
    return s;
}
int main()
{
    string s;
    getline(cin,s);
    replaceSpaces(s);
    cout<<s;
}

