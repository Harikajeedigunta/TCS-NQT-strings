#include<iostream>
#include<vector>
using namespace std;
bool compareStrings(string s1,string s2)
{
    if(s1.length()!=s2.length()) return false;
    for(int i=0;i<s1.length();i++)
    {
        if(s1[i]!=s2[i]) return false;
    }
    return true;
}
int main()
{
    string s1,s2;
    cin>>s1>>s2;
    bool ans=compareStrings(s1,s2);
    if(ans) cout<<"True";
    else cout<<"False";
}

