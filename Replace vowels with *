#include<iostream>
#include<string>
using namespace std;
string replaceVowelsWith(string &s)
{
    for(int i=0;i<s.length();i++)
    {
        if((s[i]=='a' || s[i]=='e' || s[i]=='i' || s[i]=='o' || s[i]=='u') || (s[i]=='A' || s[i]=='E' || s[i]=='I' || s[i]=='O' || s[i]=='U'))
        {
            s[i]='*';
        }
    }
    return s;
}
int main()
{
    string s;
    getline(cin,s);
    string res=replaceVowelsWith(s);
    cout<<res;
}

