#include<iostream>
using namespace std;
long long sumDigits(const string& s)
{
    long long total=0;
    int n=s.length();
    for(int i=0;i<n;i++)
    {
        total+=s[i]-'0';
    }
    return total;
}
int main()
{
    string s;
    getline(cin,s);
    cout<<sumDigits(s);
}

