#include<iostream>
#include<string>
using namespace std;
bool isPalindrome(string s)
{
    int left=0;
    int right=s.length()-1;
    while(left<right)
    {
        if(s[left]!=s[right])
        {
            return false;
        }
        left++;
        right--;
    }
    return true;
}
int main()
{
    string s;
    getline(cin,s);
    bool ans=isPalindrome(s);
    if(ans) cout<<"True"<<endl;
    else cout<<"False"<<endl;
}

