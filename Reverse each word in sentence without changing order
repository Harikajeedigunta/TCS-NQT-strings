#include<iostream>
#include<algorithm>
using namespace std;
void reverseSegment(string &s,int start,int end)
{
    while(start<end)
    {
        swap(s[start++],s[end--]);
    }
}
string reverseEachWord(string &s)
{
    int n=s.length();
    int start=0;
    for(int i=0;i<=n;i++)
    {
        if(i==n || s[i]==' ')
        {
            reverseSegment(s,start,i-1);
            start=i+1;
        }
    }
    return s;
}
int main()
{
    string s;
    getline(cin,s);
    reverseEachWord(s);
    cout<<s;
}

