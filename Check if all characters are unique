#include<iostream>
using namespace std;
bool isUnique(string s)
{
    if(s.empty()) return true;
    if(s.length()>256) return false;
    bool freq[256]={0};
    for(unsigned char c:s)
    {
        if(freq[c])
        {
            return false;
        }
        freq[c]=true;
    }
    return true;
}
int main()
{
    string s;
    getline(cin,s);
    bool ans=isUnique(s);
    if(ans) cout<<"True"<<"\n";
    else cout<<"False"<<endl;
}

