#include<iostream>
#include<algorithm>
using namespace std;
bool isPalindrome(string s)
{
    int first=0,last=s.length()-1;
    while(first<last)
    {
        if(s[first]!=s[last])
        {
            return false;
        }
        first++;
        last--;
    }
    return true;
}
int main()
{
    string s;
    cin>>s;
    bool ans=isPalindrome(s);
    if(ans) cout<<"True"<<endl;
    else cout<<"False"<<endl;
}

