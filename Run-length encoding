#include<iostream>
#include<string>
using namespace std;
string runLengthEncoding(string &s)
{
    int n=s.length();
    if(n==0) return "";
    string compressed="";
    for(int i=0;i<n;i++)
    {
        int count=1;
        while(i<n-1 && s[i]==s[i+1])
        {
            count++;
            i++;
        }
        compressed+=s[i];
        compressed+=to_string(count);
    }
    return compressed;
}
int main()
{
    string s;
    getline(cin,s);
    string result=runLengthEncoding(s);
    cout<<result<<endl;
}

