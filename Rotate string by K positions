#include<iostream>
#include<algorithm>
#include<string>
using namespace std;
string rotateStringByK(string &s,int k)
{
    int n=s.length();
    if(n==0) return s;
    k=k%n;
    if(k==0) return s;
    reverse(s.begin()+k,s.end());
    reverse(s.begin(),s.begin()+k);
    reverse(s.begin(),s.end());
    return s;
}
int main()
{
    string s;
    int k;
    getline(cin,s);
    cin>>k;
    string res=rotateStringByK(s,k);
    cout<<s;
}

