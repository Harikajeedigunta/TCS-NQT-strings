#include<iostream>
#include<vector>
using namespace std;
string reverseString(string s)
{
    int first=0,last=s.length()-1;
    while(first<last)
    {
        swap(s[first],s[last]);
        first++;
        last--;
    }
    return s;
}
int main()
{
    string s;
    cin>>s;
    cout<<reverseString(s);
}

